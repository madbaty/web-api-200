    {
      "id": "BVDSt6-W3BoEFT4HJcCne",
      "type": "text",
      "x": 1711,
      "y": 239,
      "width": 503.319580078125,
      "height": 625,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
