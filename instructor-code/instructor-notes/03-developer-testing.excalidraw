    {
      "id": "wvK_rdblNsK3AafC84dL4",
      "type": "text",
      "x": 497,
      "y": 2069,
      "width": 610.6995849609375,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aQ",
      "roundness": null,
      "seed": 1392696914,
      "version": 63,
      "versionNonce": 846355154,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773082143422,
      "link": null,
      "locked": false,
      "text": "SOA - the second worse integration pattern and they all suck.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SOA - the second worse integration pattern and they all suck.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "KvmMtOQe3dH21fTO4gqJ9",
      "type": "text",
      "x": 525,
      "y": 2575,
      "width": 706.6595458984375,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aR",
      "roundness": null,
      "seed": 476903374,
      "version": 138,
      "versionNonce": 2090369038,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773082231120,
      "link": null,
      "locked": false,
      "text": "Monoliths are the BEST - everything is early bound, one code base, etc.\nbut you outgrow those at some number of developers/teams.\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Monoliths are the BEST - everything is early bound, one code base, etc.\nbut you outgrow those at some number of developers/teams.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "rG61ShLlVcQy_msmrpVj0",
      "type": "text",
      "x": 1225,
      "y": 1958,
      "width": 260.25982666015625,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aS",
      "roundness": null,
      "seed": 1629586258,
      "version": 107,
      "versionNonce": 1777499150,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773082320857,
      "link": null,
      "locked": false,
      "text": "1. RPCs (that's http calls)\n2. Async Messaging\n3. Shared Database\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. RPCs (that's http calls)\n2. Async Messaging\n3. Shared Database\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "upbDYfDaBKuHEFWIGjJ_Y",
      "type": "text",
      "x": 1230,
      "y": 288,
      "width": 388.2397155761719,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aT",
      "roundness": null,
      "seed": 214560654,
      "version": 53,
      "versionNonce": 1844520078,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773082852808,
      "link": null,
      "locked": false,
      "text": "it isn't using the \"real\" notification API\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "it isn't using the \"real\" notification API\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "ujZ7i5Y05iB7ZqLJ5pY-R",
      "type": "text",
      "x": 317,
      "y": 734,
      "width": 805.5394287109375,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
