      "versionNonce": 1057408530,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773083124947,
      "link": null,
      "locked": false,
      "text": "punt - not so confident \n- \"end to end\" tests - these should be black box, and should run in an environment\nthat \"simulates\" production (e.g. NOT a pipeline)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "punt - not so confident \n- \"end to end\" tests - these should be black box, and should run in an environment\nthat \"simulates\" production (e.g. NOT a pipeline)",
