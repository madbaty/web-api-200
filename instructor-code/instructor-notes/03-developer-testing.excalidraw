    },
    {
      "id": "iMoYi5wUTbDYL5t4_MMGO",
      "type": "text",
      "x": 1241,
      "y": 453,
      "width": 454.1397705078125,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a6",
      "roundness": null,
      "seed": 1932216082,
      "version": 250,
      "versionNonce": 487105742,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773082818953,
      "link": null,
      "locked": false,
      "text": "Focused on the system (app)\nin isolation from it's backing services\n(fully mocked, isolated)\n\nThe set of system tests that are\npassing on your API are equal\nto you and your teams confidence\nthat this code COULD be put into production.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Focused on the system (app)\nin isolation from it's backing services\n(fully mocked, isolated)\n\nThe set of system tests that are\npassing on your API are equal\nto you and your teams confidence\nthat this code COULD be put into production.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "6FvtmNDRXOQAox8gwunAn",
      "type": "text",
      "x": 341,
      "y": 466,
      "width": 731.8995971679688,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a7",
      "roundness": null,
      "seed": 608901710,
      "version": 274,
      "versionNonce": 2052523150,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773081388612,
      "link": null,
      "locked": false,
      "text": "Test as much as possible from the \"POV\" of the consumer of this service.\nMake HTTP requests to the API, look at the response. \nCome up with scenarios that demonstrate through a test the api currently\nand in the future provides that functionality.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Test as much as possible from the \"POV\" of the consumer of this service.\nMake HTTP requests to the API, look at the response. \nCome up with scenarios that demonstrate through a test the api currently\nand in the future provides that functionality.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "GOom5BV1v6CVJHBsKqiiH",
      "type": "text",
      "x": 303,
      "y": 1004,
      "width": 839.699462890625,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a8",
      "roundness": null,
      "seed": 2049874514,
      "version": 234,
      "versionNonce": 1812813330,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773081847984,
      "link": null,
      "locked": false,
      "text": "When we add a vendor how do we know it \"worked\" \n\n\n- If I add one, get a success status code, I should be able to retrieve it again later.\n    -- this proves it is in a database, all that stuff.\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "When we add a vendor how do we know it \"worked\" \n\n\n- If I add one, get a success status code, I should be able to retrieve it again later.\n    -- this proves it is in a database, all that stuff.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "SEl890omnhUAPbrZ5vXuH",
      "type": "text",
      "x": 340,
      "y": 210,
      "width": 733.45947265625,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a9",
      "roundness": null,
      "seed": 2048073870,
      "version": 188,
      "versionNonce": 353984846,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773081893518,
      "link": null,
      "locked": false,
      "text": "Super fast - no database, no network, no file system\n\nunit integration - maybe a little bit of stuff about databases and all that,\nbut probably mocked because you don't own them.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Super fast - no database, no network, no file system\n\nunit integration - maybe a little bit of stuff about databases and all that,\nbut probably mocked because you don't own them.",
      "autoResize": true,
      "lineHeight": 1.25
    },
