            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "pointOfContact": {
            "$ref": "#/components/schemas/VendorPointOfContactModel"
          }
        }
      },
      "VendorPointOfContactModel": {
        "required": [
          "name",
          "email",
          "phone"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 100,
            "minLength": 3,
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          }
        }
      }
    }
